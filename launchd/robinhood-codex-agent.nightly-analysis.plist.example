<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Replace __REPO_ROOT__ with your local checkout path before loading. -->
  <key>Label</key>
  <string>com.example.robinhood-codex-agent.nightly-analysis</string>
  <key>ProgramArguments</key>
  <array>
    <string>__REPO_ROOT__/.venv/bin/python</string>
    <string>-m</string>
    <string>trading_agent</string>
    <string>nightly-analysis</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__REPO_ROOT__</string>
  <key>EnvironmentVariables</key>
  <dict>
    <key>AGENT_ROOT</key>
    <string>__REPO_ROOT__</string>
    <key>CODEX_BIN</key>
    <string>/Users/yinyin-jiang/.codex/packages/standalone/releases/0.137.0-aarch64-apple-darwin/bin/codex</string>
    <key>PATH</key>
    <string>/Users/yinyin-jiang/.local/bin:/Users/yinyin-jiang/.codex/packages/standalone/releases/0.137.0-aarch64-apple-darwin/bin:/Users/yinyin-jiang/Documents/trade/robinhood-codex-agent/.venv/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>
  <!-- 20:00 PT on weekdays (after the close, so the day's daily bar has settled). -->
  <key>StartCalendarInterval</key>
  <array>
    <dict><key>Weekday</key><integer>1</integer><key>Hour</key><integer>20</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Weekday</key><integer>2</integer><key>Hour</key><integer>20</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Weekday</key><integer>3</integer><key>Hour</key><integer>20</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Weekday</key><integer>4</integer><key>Hour</key><integer>20</integer><key>Minute</key><integer>0</integer></dict>
    <dict><key>Weekday</key><integer>5</integer><key>Hour</key><integer>20</integer><key>Minute</key><integer>0</integer></dict>
  </array>
  <key>StandardOutPath</key>
  <string>__REPO_ROOT__/runtime/logs/launchd.nightly-analysis.out</string>
  <key>StandardErrorPath</key>
  <string>__REPO_ROOT__/runtime/logs/launchd.nightly-analysis.err</string>
</dict>
</plist>
