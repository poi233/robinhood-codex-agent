<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Replace __REPO_ROOT__ with your local checkout path before loading. -->
  <!-- Nightly read-only / shadow-only analysis batch (I1). Never trades, approves, or promotes.
       Runs the package entrypoint directly to avoid launchd/TCC shell-wrapper failures. -->
  <key>Label</key>
  <string>com.example.robinhood-codex-agent.nightly-analysis</string>
  <key>ProgramArguments</key>
  <array>
    <string>__PYTHON_BIN__</string>
    <string>-m</string>
    <string>trading_agent</string>
    <string>nightly-analysis</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__REPO_ROOT__</string>
  <key>EnvironmentVariables</key>
  <dict>
    <!-- Optional (the script also derives it), but makes the run explicit. -->
    <key>AGENT_ROOT</key>
    <string>__REPO_ROOT__</string>
    <!-- Portable PATH only. Do NOT hardcode a versioned codex release dir or a user home:
         codex auto-updates and those paths disappear, silently breaking runs. -->
    <key>PATH</key>
    <string>__REPO_ROOT__/.venv/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>
  <!-- Rendered by src/scripts/launchd/install_launchd_jobs.sh as postmarket + 30 minutes on weekdays. -->
  <key>StartCalendarInterval</key>
  <array>
    <!-- __NIGHTLY_SCHEDULE__ -->
  </array>
  <key>StandardOutPath</key>
  <string>__LAUNCHD_LOG_DIR__/launchd.nightly-analysis.out</string>
  <key>StandardErrorPath</key>
  <string>__LAUNCHD_LOG_DIR__/launchd.nightly-analysis.err</string>
</dict>
</plist>
