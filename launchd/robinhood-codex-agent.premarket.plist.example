<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Replace __REPO_ROOT__ with your local checkout path before loading. -->
  <!-- Runs the entrypoint script (not python directly), so it stays portable: the script
       derives AGENT_ROOT from its own location and resolves a working Python via
       resolve_runtime_python_bin (.venv -> python3 -> homebrew -> system). Nothing here is
       pinned to a specific .venv, codex version, or user home. -->
  <key>Label</key>
  <string>com.example.robinhood-codex-agent.premarket</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__REPO_ROOT__/src/scripts/entrypoints/run_premarket.sh</string>
  </array>
  <key>WorkingDirectory</key>
  <string>__REPO_ROOT__</string>
  <key>EnvironmentVariables</key>
  <dict>
    <!-- Optional (the script also derives it), but makes the run explicit. -->
    <key>AGENT_ROOT</key>
    <string>__REPO_ROOT__</string>
    <!-- Portable PATH only. Do NOT hardcode a versioned codex release dir or a user home:
         codex auto-updates and those paths disappear, silently breaking runs. codex is
         resolved from CODEX_BIN (set a stable path in src/config/runtime.env.local if
         needed), PATH, or common install locations including ~/.local/bin. -->
    <key>PATH</key>
    <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
  </dict>
  <key>StartCalendarInterval</key>
  <dict>
    <key>Hour</key>
    <integer>5</integer>
    <key>Minute</key>
    <integer>30</integer>
  </dict>
  <key>StandardOutPath</key>
  <string>__REPO_ROOT__/runtime/logs/launchd.premarket.out</string>
  <key>StandardErrorPath</key>
  <string>__REPO_ROOT__/runtime/logs/launchd.premarket.err</string>
</dict>
</plist>
