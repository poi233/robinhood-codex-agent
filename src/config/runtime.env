# Runtime mode for scheduled scripts.
# Valid values:
# - paper: write would_trade decisions only; do not call review/place order tools.
# - review: allow review_equity_order only; never place orders.
# - live: allow place_equity_order only after all local/prompt/review gates pass.
#
# review/live use the SAME deterministic policy engine as paper; the only
# difference is execution — paper simulates the fill, review/live hand the exact
# engine-decided order to a thin execute prompt (LLM as executor only, no
# independent analysis). KILL_SWITCH and all local gates apply in every mode.
TRADING_MODE=paper

# Two-tier Codex model routing. Reasoning-heavy prompts (final_premarket,
# dsa_premarket_scan, screener_discover, intraday, postmarket) use CODEX_MODEL;
# simple / advisory prompts (account_snapshot, market_calendar,
# quote_snapshot_core, catalyst_enrichment, technical_research narrative,
# intraday_snapshot, intraday_execute, email_*) use CODEX_MODEL_MINI. Set
# CODEX_MODEL_FORCE to pin every prompt to one model.
CODEX_MODEL=gpt-5.4
CODEX_MODEL_MINI=gpt-5.4-mini
CODEX_BIN=codex
CODEX_EXEC_TIMEOUT_SEC=3600

# Technical layer is hybrid: decision-critical signals (action/levels/setups) are
# computed deterministically in Python (signals/technical_engine) from ALL the
# computed features (multi-timeframe + EMA + relative strength + ATR + flags). A
# mini-model LLM pass then writes chan/Brooks/fundamentals narrative AND a
# structured llm_assessment, which apply_llm_assessment folds into the decision
# within hard bounds. TECHNICAL_LLM_MAX_SWING caps how far the LLM may move
# priority_score (≈ one action band); it can never edit price levels/stops.
TECHNICAL_LLM_MAX_SWING=12

DSA_MAX_SUBAGENTS=3
DSA_METRICS_LOOKBACK_DAYS=180

# Risk tier (and SCORING_PROFILE/POLICY_PROFILE) now come from the active
# strategy in src/config/strategy_registry.yaml, not from this file. Set
# RISK_TIER/PAPER_RISK_TIER here (or in runtime.env.local) only to manually
# override the registry for a one-off test; they always win over the
# registry default when present.
# Tier reference: 0 initial paper/review/live micro test, 1 small live,
# 2 moderate live, 3 aggressive live for a small dedicated Agentic Account,
# 4 paper_max (paper-only; risk-budget/portfolio-weight caps become the binding limit).

# Local run guardrails. Prompts also enforce these.
MAX_SINGLE_ORDER_NOTIONAL=5000
MAX_DAILY_NOTIONAL=20000

# Kronos forecast layer.
KRONOS_MODEL_NAME=NeoQuasar/Kronos-base
KRONOS_TOKENIZER_NAME=NeoQuasar/Kronos-Tokenizer-base
KRONOS_TIMEFRAME=30m
KRONOS_LOOKBACK_BARS=512
KRONOS_HORIZON_BARS=8
KRONOS_TEMPERATURE=1.0
KRONOS_TOP_P=0.9
KRONOS_SAMPLE_COUNT=1
KRONOS_MIN_CONFIDENCE=0.60

TECHNICAL_MAX_SUBAGENTS=3
TECHNICAL_RECENT_BARS=30

MARKET_FEED_PYTHON_BIN=python3
MARKET_FEED_TIMEFRAMES=1w,1d,1h,15m
MARKET_FEED_NEWS_LIMIT=5

TECHNICAL_SIGNALS_FILE=runtime/state/technical_signals.json
PAPER_STARTING_CASH=400000

# Partial fills (default off, preserves all-or-nothing behavior). When on, a quote
# that has just barely cleared the limit fills at PAPER_PARTIAL_FILL_MIN_RATIO of the
# order, scaling up to a full fill once it's PAPER_PARTIAL_FILL_THRESHOLD_BPS or more
# through the limit. The unfilled remainder re-queues as a smaller pending order.
PAPER_PARTIAL_FILL=0
PAPER_PARTIAL_FILL_MIN_RATIO=0.3
PAPER_PARTIAL_FILL_THRESHOLD_BPS=20

# O1 weekly Serenity-skill stock screener (selection layer): the weekly cron
# auto-updates the universe ADD-ONLY (never delete) + re-rank, rate-limited +
# capped. Selection layer only — never touches sizing/risk. (`screen --dry-run`
# still forces report-only for a one-off.)
SCREEN_MAX_ADDS_PER_WEEK=5
# Universe size cap: when exceeded, the lowest screen_rank symbols are demoted to
# tier:passive (excluded from AI layers but kept in the file — never deleted).
UNIVERSE_MAX=120
# Strict factor gate: minimum average dollar volume (price*volume) to be eligible.
SCREEN_MIN_DOLLAR_VOL=20000000
# Strict factor gate: require an uptrend (above SMA200 / not broken down) to be eligible.
SCREEN_REQUIRE_UPTREND=1

# O2 daily dynamic active selection: premarket picks the active set each day as
# pins (active_watchlist anchors) ∪ the top-ACTIVE_MAX universe symbols by
# screen_score (written weekly by O1), to planner/active_selection.{json,txt}.
ACTIVE_MAX=30
